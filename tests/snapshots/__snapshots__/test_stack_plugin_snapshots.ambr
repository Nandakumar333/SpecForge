# serializer version: 1
# name: test_plugin_rules_snapshot[microservice-dotnet]
  '''
  
  ### BACK-DOTNET-MS-001: Per-Service DbContext Isolation
  severity: ERROR
  scope: all EF Core DbContext classes
  rule: Each microservice MUST define its own DbContext scoped to its bounded context. Cross-service DbContext sharing is forbidden.
  threshold: max_dbcontexts_per_service=1
  example_correct: |
    public class OrderDbContext : DbContext { ... }
  example_incorrect: |
    public class SharedDbContext : DbContext { /* used by multiple services */ }
  
  ### BACK-DOTNET-MS-002: Multi-Stage Docker Container Build
  severity: ERROR
  scope: Dockerfile per service
  rule: Each microservice MUST use a multi-stage Docker build with separate SDK, publish, and runtime stages for minimal images.
  threshold: min_build_stages=3
  example_correct: |
    FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
    FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
  example_incorrect: |
    FROM mcr.microsoft.com/dotnet/sdk:8.0
    RUN dotnet publish
  
  ### BACK-DOTNET-MS-003: gRPC Proto Contract Definitions
  severity: WARNING
  scope: inter-service communication
  rule: Synchronous inter-service calls SHOULD use gRPC with shared .proto contract files in a dedicated contracts project.
  threshold: proto_location=src/Contracts/Protos/
  example_correct: |
    syntax = "proto3";
    service OrderService { ... }
  example_incorrect: |
    var client = new HttpClient();
    await client.GetAsync("http://order-service/api/orders");
  
  ### BACK-DOTNET-MS-004: MassTransit Event Handler Registration
  severity: ERROR
  scope: async messaging consumers
  rule: All asynchronous event handlers MUST be registered via MassTransit consumers with explicit queue/topic bindings.
  threshold: max_unregistered_handlers=0
  example_correct: |
    cfg.ReceiveEndpoint("order-created", e => {
        e.ConfigureConsumer<OrderCreatedConsumer>(ctx);
    });
  example_incorrect: |
    bus.Publish(new OrderCreated());
    // No consumer registration
  
  ### DB-DOTNET-MS-001: Database-Per-Service Pattern
  severity: ERROR
  scope: database provisioning
  rule: Each microservice MUST own its database or schema. No shared database tables across service boundaries.
  threshold: max_shared_tables=0
  example_correct: |
    ConnectionStrings__OrderDb=Server=db;Database=orders;
  example_incorrect: |
    ConnectionStrings__SharedDb=Server=db;Database=app;
  
  ### DB-DOTNET-MS-002: EF Core Migration Per Service
  severity: WARNING
  scope: migration scripts
  rule: Each service SHOULD manage its own EF Core migrations independently of other services.
  threshold: migrations_per_service=separate
  example_correct: |
    dotnet ef migrations add Init --project OrderService
  example_incorrect: |
    dotnet ef migrations add Init --project SharedMigrations
  
  ### CICD-DOTNET-MS-001: Independent Service Build Pipelines
  severity: ERROR
  scope: CI/CD configuration
  rule: Each microservice MUST have its own build pipeline that triggers only on changes within its directory.
  threshold: pipelines_per_service=1
  example_correct: |
    trigger:
      paths:
        - src/Services/OrderService/**
  example_incorrect: |
    trigger:
      paths:
        - src/**  # triggers on all changes
  
  ### CICD-DOTNET-MS-002: Container Image Tagging
  severity: WARNING
  scope: image registry
  rule: Built images SHOULD use semantic version tags and commit SHA for traceability. Latest-only tagging is discouraged.
  threshold: required_tags=semver,sha
  example_correct: |
    docker tag order-service:1.2.3 order-service:abc1234
  example_incorrect: |
    docker tag order-service:latest
  
  '''
# ---
# name: test_plugin_rules_snapshot[microservice-nodejs]
  '''
  
  ### BACK-NODEJS-MS-001: Express/Fastify Per-Service Application
  severity: ERROR
  scope: service entry points
  rule: Each microservice MUST have its own Express or Fastify application instance with isolated route registration.
  threshold: max_apps_per_service=1
  example_correct: |
    // order-service/src/app.ts
    const app = express();
    app.use('/orders', orderRoutes);
  example_incorrect: |
    // shared/app.ts
    const app = express();  // single app for all services
  
  ### BACK-NODEJS-MS-002: Multi-Stage Docker Container Build
  severity: ERROR
  scope: Dockerfile per service
  rule: Each microservice MUST use a multi-stage Docker build with node:alpine base image for minimal production images.
  threshold: min_build_stages=2
  example_correct: |
    FROM node:20-alpine AS builder
    FROM node:20-alpine AS runtime
  example_incorrect: |
    FROM node:20
    RUN npm install && npm start
  
  ### BACK-NODEJS-MS-003: Prisma/TypeORM Per-Service Schema Isolation
  severity: ERROR
  scope: ORM schema and client
  rule: Each microservice MUST define its own Prisma schema or TypeORM data source. Shared schemas across services are forbidden.
  threshold: max_shared_schemas=0
  example_correct: |
    // order-service/prisma/schema.prisma
    datasource db { url = env("ORDER_DB_URL") }
  example_incorrect: |
    // shared/prisma/schema.prisma
    // Single schema used by multiple services
  
  ### BACK-NODEJS-MS-004: NATS/RabbitMQ Message Broker Integration
  severity: WARNING
  scope: async messaging
  rule: Asynchronous cross-service communication SHOULD use NATS or RabbitMQ message broker with explicit topic/queue bindings.
  threshold: max_unregistered_handlers=0
  example_correct: |
    nats.subscribe('order.created', (msg) => {
      handleOrderCreated(msg.data);
    });
  example_incorrect: |
    // Direct HTTP call for async operation
    await fetch('http://payment-service/process', { method: 'POST' });
  
  ### DB-NODEJS-MS-001: Database-Per-Service Pattern
  severity: ERROR
  scope: database provisioning
  rule: Each microservice MUST own its database or schema. No shared database tables across service boundaries.
  threshold: max_shared_tables=0
  example_correct: |
    DATABASE_URL="postgresql://db/order_service_db"
  example_incorrect: |
    DATABASE_URL="postgresql://db/shared_app_db"
  
  ### DB-NODEJS-MS-002: Prisma Migration Per Service
  severity: WARNING
  scope: migration scripts
  rule: Each service SHOULD manage its own Prisma migrations independently of other services.
  threshold: migrations_per_service=separate
  example_correct: |
    npx prisma migrate deploy --schema=order-service/prisma/schema.prisma
  example_incorrect: |
    npx prisma migrate deploy --schema=shared/prisma/schema.prisma
  
  ### CICD-NODEJS-MS-001: Independent Service Build Pipelines
  severity: ERROR
  scope: CI/CD configuration
  rule: Each microservice MUST have its own build pipeline that triggers only on changes within its directory.
  threshold: pipelines_per_service=1
  example_correct: |
    trigger:
      paths:
        - services/order-service/**
  example_incorrect: |
    trigger:
      paths:
        - '**'  # triggers on all changes
  
  ### CICD-NODEJS-MS-002: Per-Service Image Tagging
  severity: WARNING
  scope: image registry
  rule: Built images SHOULD use semantic version tags and commit SHA for traceability. Latest-only tagging is discouraged.
  threshold: required_tags=semver,sha
  example_correct: |
    docker tag order-service:1.2.3 order-service:abc1234
  example_incorrect: |
    docker tag order-service:latest
  
  '''
