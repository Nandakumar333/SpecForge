    // API references Application
    // Application references Domain
    // Infrastructure references Domain
  example_incorrect: |
    // Domain references Infrastructure
    // Circular dependency
  
  ### BACK-DOTNET-MO-004: Synchronous In-Process Communication
  severity: WARNING
  scope: module communication
  rule: Modules within the monolith SHOULD communicate via direct method calls or mediator pattern, not HTTP or message queues.
  threshold: max_http_internal_calls=0
  example_correct: |
    await _mediator.Send(new GetOrderQuery(id));
  example_incorrect: |
    await _httpClient.GetAsync("http://localhost/api/orders");
  
  ### DB-DOTNET-MO-001: Unified Migration Pipeline
  severity: ERROR
  scope: database migrations
  rule: All database migrations MUST be managed through a single migration pipeline using EF Core migrations.
  threshold: migration_projects=1
  example_correct: |
    dotnet ef migrations add AddOrders --project App.Infrastructure
  example_incorrect: |
    Manual SQL scripts applied outside EF Core migration pipeline
  
  ### DB-DOTNET-MO-002: Schema-Based Module Separation
  severity: WARNING
  scope: database schema design
  rule: Domain modules SHOULD use separate database schemas within the single database for logical isolation.
  threshold: min_schemas=1
  example_correct: |
    modelBuilder.Entity<Order>().ToTable("Orders", schema: "ordering");
  example_incorrect: |
    modelBuilder.Entity<Order>().ToTable("Orders"); // default dbo schema
  
  ### CICD-DOTNET-MO-001: Unified Build Pipeline
  severity: ERROR
  scope: CI/CD configuration
  rule: The monolith MUST have a single build pipeline that compiles, tests, and packages the entire solution.
  threshold: pipeline_count=1
  example_correct: |
    dotnet build App.sln && dotnet test App.sln
  example_incorrect: |
    Separate pipelines for each project within the monolith
  
  ### CICD-DOTNET-MO-002: Solution-Level Test Execution
  severity: WARNING
  scope: test pipeline step
  rule: CI pipeline SHOULD run tests at the solution level to ensure all modules are tested together.
  threshold: test_scope=solution
  example_correct: |
    dotnet test App.sln --configuration Release
  example_incorrect: |
    dotnet test App.Api.Tests.csproj  # misses other test projects
  
  '''
# ---
# name: test_plugin_rules_snapshot[monolithic-nodejs]
  '''
  
  ### BACK-NODEJS-MO-001: Single Application Entry Point
  severity: ERROR
  scope: application startup
  rule: The monolith MUST have a single application entry point with centralized middleware and route registration.
  threshold: max_entry_points=1
  example_correct: |
    // src/app.ts
    const app = express();
    app.use('/api/orders', orderRoutes);
    app.use('/api/users', userRoutes);
  example_incorrect: |
    // Multiple separate Express apps running independently
    const ordersApp = express();
    const usersApp = express();
  
  ### BACK-NODEJS-MO-002: Shared Prisma Schema Definition
  severity: WARNING
  scope: ORM schema
  rule: All domain models SHOULD be defined in a single Prisma schema file for unified migration management.
  threshold: max_schemas=1
  example_correct: |
    // prisma/schema.prisma
    model Order { id Int @id }
    model User { id Int @id }
  example_incorrect: |
    // prisma/order.prisma and prisma/user.prisma
    // Separate schema files causing migration conflicts
  
  ### BACK-NODEJS-MO-003: Layered Directory Structure
  severity: ERROR
  scope: project organization
  rule: The monolith MUST follow layered architecture with separate directories for routes, services, models, and middleware.
  threshold: required_layers=routes,services,models
  example_correct: |
    src/routes/orderRoutes.ts
    src/services/orderService.ts
    src/models/order.ts
  example_incorrect: |
    src/orders.ts  // mixes routes, logic, and data access
  
  ### BACK-NODEJS-MO-004: Synchronous In-Process Communication
  severity: WARNING
  scope: module interaction
  rule: Modules within the monolith SHOULD communicate via direct function calls or service injection, not HTTP or message queues.
  threshold: max_internal_http_calls=0
  example_correct: |
    const order = await orderService.getOrder(id);
  example_incorrect: |
    const order = await fetch(`http://localhost/api/orders/${id}`);
  
  ### DB-NODEJS-MO-001: Unified Migration Pipeline
  severity: ERROR
  scope: database migrations
  rule: All database migrations MUST be managed through a single Prisma migration pipeline.
  threshold: migration_schemas=1
  example_correct: |
    npx prisma migrate deploy
  example_incorrect: |
    Multiple prisma schema files with separate migration dirs
  
  ### DB-NODEJS-MO-002: Schema-Based Module Separation
  severity: WARNING
  scope: database schema design
  rule: Domain modules SHOULD use naming prefixes or PostgreSQL schemas within the single database for logical isolation.
  threshold: min_prefixes=1
  example_correct: |
    model OrdersOrder {
      @@map("orders_orders")
    }
  example_incorrect: |
    model Order {
      @@map("orders")  // generic name, no module prefix
    }
  
  ### CICD-NODEJS-MO-001: Unified Build Pipeline
  severity: ERROR
  scope: CI/CD configuration
  rule: The monolith MUST have a single build pipeline that runs linting, tests, and build for the entire project.
  threshold: pipeline_count=1
  example_correct: |
    npm ci && npm run lint && npm test && npm run build
  example_incorrect: |
    Separate pipelines for each module within the monolith
  
  ### CICD-NODEJS-MO-002: Full Test Suite Execution
  severity: WARNING
  scope: test pipeline step
  rule: CI pipeline SHOULD run the complete test suite to ensure all modules are tested together.
  threshold: test_scope=full
  example_correct: |
    npm test  # runs all tests
  example_incorrect: |
    npm test -- --testPathPattern=orders  # misses other modules
  
  '''
# ---
# name: test_plugin_rules_snapshot[monolithic-python]
  '''
  
  ### BACK-PYTHON-MO-001: Single Application Entry Point
  severity: ERROR
  scope: application startup
  rule: The monolith MUST have a single application entry point with centralized configuration and middleware registration.
  threshold: max_entry_points=1
  example_correct: |
    # app/main.py
    app = FastAPI(title='MyApp')
    app.include_router(orders.router)
  example_incorrect: |
    # Multiple separate FastAPI apps running independently
    orders_app = FastAPI()
    payments_app = FastAPI()
  
  ### BACK-PYTHON-MO-002: Shared SQLAlchemy Model Base
  severity: WARNING
  scope: ORM model definitions
  rule: All domain models SHOULD inherit from a single SQLAlchemy declarative Base for unified migration management.
  threshold: max_bases=1
  example_correct: |
    # app/models/base.py
    Base = declarative_base()
    # app/models/order.py
    class Order(Base): ...
  example_incorrect: |
    OrderBase = declarative_base()
    UserBase = declarative_base()  # separate bases
  
  ### BACK-PYTHON-MO-003: Layered Package Structure
  severity: ERROR
  scope: package organization
  rule: The monolith MUST follow layered architecture with separate packages for API, services, models, and repositories.
  threshold: required_layers=api,services,models
  example_correct: |
    app/api/routes.py
    app/services/order_service.py
    app/models/order.py
  example_incorrect: |
    app/orders.py  # mixes routes, logic, and data access
  
  ### BACK-PYTHON-MO-004: Synchronous In-Process Communication
  severity: WARNING
  scope: module interaction
  rule: Modules within the monolith SHOULD communicate via direct function calls or service layer methods, not HTTP or queues.
  threshold: max_internal_http_calls=0
  example_correct: |
    result = order_service.get_order(order_id)
  example_incorrect: |
    result = httpx.get(f'http://localhost/api/orders/{order_id}')
  
  ### DB-PYTHON-MO-001: Unified Alembic Migration Pipeline
  severity: ERROR
  scope: database migrations
  rule: All database migrations MUST be managed through a single Alembic migration environment.
  threshold: migration_envs=1
  example_correct: |
    alembic upgrade head  # single migration env
  example_incorrect: |
    Multiple alembic.ini files for different modules
  
  ### DB-PYTHON-MO-002: Schema-Based Module Separation
  severity: WARNING
  scope: database schema design
  rule: Domain modules SHOULD use separate database schemas within the single database for logical isolation.
  threshold: min_schemas=1
  example_correct: |
    class Order(Base):
        __table_args__ = {"schema": "ordering"}
  example_incorrect: |
    class Order(Base):
        __tablename__ = "orders"  # default public schema
  
  ### CICD-PYTHON-MO-001: Unified Build Pipeline
  severity: ERROR
  scope: CI/CD configuration
  rule: The monolith MUST have a single build pipeline that runs linting, tests, and packaging for the entire project.
  threshold: pipeline_count=1
  example_correct: |
    pip install -e . && pytest && ruff check .
  example_incorrect: |
    Separate pipelines for each module within the monolith
  
  ### CICD-PYTHON-MO-002: Full Test Suite Execution
  severity: WARNING
  scope: test pipeline step
  rule: CI pipeline SHOULD run the complete pytest suite to ensure all modules are tested together.
  threshold: test_scope=full
  example_correct: |
    pytest tests/ --cov=app
  example_incorrect: |
    pytest tests/orders/  # misses other modules
  
  '''
# ---
